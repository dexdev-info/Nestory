// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  compilerBuild = "fast"  // "fast" (default) | "small" — v7.3.0+
}

generator nestjsDto {
  provider      = "prisma-generator-nestjs-dto"
  output        = "../src/generated/nestjs-dto"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================
// MODELS
// ============================================

model User {
  id               String         @id @default(cuid())
  // email và user name không đặt unique ở đây -> unique + partial index trong migration
  email            String         @db.VarChar(255)
  username         String         @db.VarChar(50)
  passwordHash     String         @db.VarChar(255)

  name             String         @db.VarChar(255)
  bio              String?        @db.Text
  avatarUrl        String?        @db.VarChar(500)

  role             UserRole       @default(USER)
  isActive         Boolean        @default(true)
  isVerified       Boolean        @default(false)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  refreshTokens    RefreshToken[]
  posts            Post[]
  claps            Clap[]
  comments         Comment[]

  // partial index -> WHERE deletedAt IS NULL

  @@map("users")
}

model RefreshToken {
  id               String         @id @default(cuid())
  tokenHash        String         @unique @db.VarChar(255)
  
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  userAgent        String?        @db.Text
  ipAddress        String?        @db.VarChar(45)
  
  isRevoked        Boolean        @default(false)
  expiresAt        DateTime
  createdAt        DateTime       @default(now())

  // partial index -> WHERE "isRevoked" = false;

  @@map("refresh_tokens")
}

model Post {
  id               String         @id @default(cuid())
  coverImage       String?        @db.VarChar(500)
  status           PostStatus     @default(DRAFT)
  viewCount        Int            @default(0)
  clapCount        Int            @default(0)
  commentCount     Int            @default(0)
  publishedAt      DateTime?

  authorId         String
  author           User           @relation(fields: [authorId], references: [id])
  categoryId       String?
  category         Category?      @relation(fields: [categoryId], references: [id])

  translations     PostTranslation[]
  tags             Tag[]          @relation("PostTags")
  comments         Comment[]
  claps            Clap[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  // partial index -> Query bài viết published, sort theo mới nhất
  // Query bài viết theo tác giả (profile page, dashboard)
  @@index([authorId, status])
  // Query bài viết theo category
  @@index([categoryId, status])
  // partial index -> WHERE deletedAt IS NULL

  @@map("posts")
}

model PostTranslation {
  id               String         @id @default(cuid())
  language         String         @db.VarChar(10)
  slug             String         @db.VarChar(255)
  title            String         @db.VarChar(255)
  excerpt          String?        @db.Text
  content          String         @db.Text
  readingTime      Int            @default(0)

  // tsv tsvector for search -> Thêm thủ công trong migration SQL

  postId           String
  post             Post           @relation(fields: [postId], references: [id], onDelete: Cascade)

  deletedAt        DateTime?

// Mỗi post chỉ có 1 bản dịch cho 1 ngôn ngữ
  @@unique([postId, language])
  // partial index -> Slug không trùng trong cùng 1 ngôn ngữ và reuseble slug

  @@map("post_translations")
}

model Category {
  id               String         @id @default(cuid())
  slug             String         @unique @db.VarChar(255)

  parentId         String?
  parent           Category?      @relation("CategoryTree", fields: [parentId], references: [id])
  children         Category[]     @relation("CategoryTree")

  posts            Post[]
  translations     CategoryTranslation[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([parentId])

  @@map("categories")
}

model CategoryTranslation {
  id               String         @id @default(cuid())
  language         String         @db.VarChar(10)
  name             String         @db.VarChar(255)

  categoryId       String
  category         Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, language])
  @@map("category_translations")
}

model Comment {
  id               String         @id @default(cuid())
  content          String         @db.Text
  replyCount       Int            @default(0)
  clapCount        Int            @default(0)

  postId           String
  post             Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId         String
  author           User           @relation(fields: [authorId], references: [id])
  parentId         String?
  parent           Comment?       @relation("CommentReplies", fields: [parentId], references: [id])
  replies          Comment[]      @relation("CommentReplies")

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  // partial index -> sort theo all | newest | relevant
  // partial index -> Query replies của 1 comment
  // Query tất cả comments của 1 user (profile/moderation)
  @@index([authorId])

  @@map("comments")
}

model Clap {
  postId           String
  userId           String
  // Tối đa 50 lần clap, validate ở application layer
  count            Int            @default(1)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  post             Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])

  @@map("claps")
}

model Tag {
  id               String         @id @default(cuid())
  name             String         @unique @db.VarChar(100)
  slug             String         @unique @db.VarChar(100)
  postCount        Int            @default(0)

  posts            Post[]         @relation("PostTags")

  // Sort tags theo popularity
  @@index([postCount(sort: Desc)]) 

  @@map("tags")
}
